# ArtiGate's Compose stack fails closed until both secrets below are set.
# Copy this file to .env; .env is gitignored.

# Build ArtiGate, run ./artigate hashpw --user admin, and paste the complete
# output below. Keep the value single-quoted so every $ in the argon2id PHC
# hash remains literal in Compose's .env parser.
ARTIGATE_LOW_AUTH=

# Generate an independent, random diode bearer token, for example with:
#   openssl rand -hex 32
ARTIGATE_DIODE_TOKEN=

# Published ports are loopback-only by default. Do not change these to a
# non-loopback address unless a TLS-authenticating reverse proxy and network
# policy protect the corresponding service.
ARTIGATE_LOW_BIND=127.0.0.1
ARTIGATE_HIGH_BIND=127.0.0.1
