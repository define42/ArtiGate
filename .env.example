# ArtiGate's Compose stack fails closed until both secrets below are set.
# Copy this file to .env; .env is gitignored.

# Build ArtiGate, run ./artigate hashpw --user admin, and paste the complete
# output below. Keep the value single-quoted so every $ in the argon2id PHC
# hash remains literal in Compose's .env parser.
ARTIGATE_LOW_AUTH=

# Generate an independent, random diode bearer token, for example with:
#   openssl rand -hex 32
ARTIGATE_DIODE_TOKEN=

# Published ports are loopback-only by default. Do not change these to a
# non-loopback address unless a TLS-authenticating reverse proxy and network
# policy protect the corresponding service.
ARTIGATE_LOW_BIND=127.0.0.1
ARTIGATE_HIGH_BIND=127.0.0.1

# Optional: POST a JSON alert on schedule_failed (low) / bundle_rejected and
# gap_detected (high). Leave unset to disable. Both sides also serve Prometheus
# metrics at GET /metrics with no configuration.
# ARTIGATE_WEBHOOK_URL=https://hooks.example.com/artigate
# ARTIGATE_WEBHOOK_TOKEN=

# Optional: standing logins for private container registries, as comma-separated
# host=user:password entries. Re-read on every collect (rotates without a
# restart) and the only credential source scheduled container pulls use. Keep
# the value single-quoted so any $ in a robot-account name or token stays
# literal in Compose's .env parser.
# ARTIGATE_CONTAINER_AUTH='ghcr.io=mirror-bot:ghp_xxx,harbor.example.com=robot$mirror:secret'

# Optional: standing logins for private git/APT/RPM/Alpine upstreams, keyed by
# the upstream's exact host (host:port included) and sent as HTTP Basic. Same
# format, rotation, and scheduled-collect role as ARTIGATE_CONTAINER_AUTH.
# ARTIGATE_UPSTREAM_AUTH='git.example.com=mirror-bot:glpat_xxx,apt.example.com=bot:secret'

# Optional: standing logins for private Go module hosts (the key is the VCS
# host), injected into the go/git subprocesses per collect; each host is also
# treated as private (GOPRIVATE/GONOSUMDB/GONOPROXY) for that collect — which
# is why Go has its own variable instead of sharing ARTIGATE_UPSTREAM_AUTH.
# ARTIGATE_GO_AUTH='gitlab.example.com=mirror-bot:glpat_xxx'
